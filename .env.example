#================================================================================================
# TelemetryFlow GO MCP Server - ENVIRONMENT CONFIGURATION
#================================================================================================
#
# Copy this file to .env and update the values.
# Compatible with TFO-Collector v1.2.1 (OCB-native) & TFO-Agent v1.2.0.
#
# SECURITY NOTICE:
#   This file contains DEFAULT VALUES suitable for DEVELOPMENT ONLY.
#   DO NOT use these values in production environments.
#
# Quick Start: README.md
# Documentation: docs/
#
#================================================================================================


#================================================================================================
# [1] APPLICATION CONFIGURATION
#================================================================================================
APP_NAME=TelemetryFlow GO MCP Server

TZ=UTC

LOG_LEVEL=info
LOG_FORMAT=json

TELEMETRYFLOW_MCP_VERSION=1.2.0
TELEMETRYFLOW_MCP_COMMIT=
TELEMETRYFLOW_MCP_BUILD_DATE=


#================================================================================================
# [2] CLAUDE API (Required)
#================================================================================================
# Your Anthropic API key
ANTHROPIC_API_KEY=your-anthropic-api-key-here

# Alternative env var name (both supported)
# TELEMETRYFLOW_MCP_CLAUDE_API_KEY=your-api-key-here

# Claude API base URL (default: https://api.anthropic.com)
# TELEMETRYFLOW_MCP_CLAUDE_BASE_URL=https://api.anthropic.com

# Default model (default: claude-opus-4-7)
# TELEMETRYFLOW_MCP_CLAUDE_DEFAULT_MODEL=claude-opus-4-7


#================================================================================================
# [3] SERVER CONFIGURATION
#================================================================================================
TELEMETRYFLOW_MCP_SERVER_HOST=localhost
TELEMETRYFLOW_MCP_SERVER_PORT=8080

# Transport: stdio | sse | websocket
TELEMETRYFLOW_MCP_SERVER_TRANSPORT=sse

TELEMETRYFLOW_MCP_DEBUG=false


#================================================================================================
# [4] LOGGING
#================================================================================================
TELEMETRYFLOW_MCP_LOG_LEVEL=info
TELEMETRYFLOW_MCP_LOG_FORMAT=json


#================================================================================================
# [5] TELEMETRYFLOW OBSERVABILITY (TELEMETRYFLOW SDK)
#================================================================================================
# Single API key (Go SDK compatibility)
TELEMETRYFLOW_API_KEY=your-telemetryflow-api-key-here

# Split API keys (Platform native)
# TELEMETRYFLOW_API_KEY_ID=tfk_your_key_id
# TELEMETRYFLOW_API_KEY_SECRET=tfs_your_key_secret

# OTLP Exporter endpoint
# Local:          localhost:4317
# Docker:         tfo-collector:4317
# Host from Docker: host.docker.internal:4317
TELEMETRYFLOW_ENDPOINT=localhost:4317

# Service Identity
TELEMETRYFLOW_SERVICE_NAME=telemetryflow-go-mcp
TELEMETRYFLOW_SERVICE_VERSION=1.2.0
TELEMETRYFLOW_SERVICE_NAMESPACE=telemetryflow
TELEMETRYFLOW_ENVIRONMENT=development
TELEMETRYFLOW_INSECURE=true


#================================================================================================
# [6] OPENTELEMETRY COMPATIBILITY (Optional)
#================================================================================================
TELEMETRYFLOW_MCP_OTLP_ENDPOINT=localhost:4317
TELEMETRYFLOW_MCP_SERVICE_NAME=telemetryflow-go-mcp


#================================================================================================
# [7] MCP PROTOCOL
#================================================================================================
TELEMETRYFLOW_MCP_ENABLE_TOOLS=true
TELEMETRYFLOW_MCP_ENABLE_RESOURCES=true
TELEMETRYFLOW_MCP_ENABLE_PROMPTS=true


#================================================================================================
# [8] REDIS (Cache L2, Session Store)
#================================================================================================
TELEMETRYFLOW_MCP_REDIS_URL=redis://localhost:6379
TELEMETRYFLOW_MCP_CACHE_ENABLED=true
TELEMETRYFLOW_MCP_CACHE_TTL=300
TELEMETRYFLOW_MCP_QUEUE_ENABLED=true
TELEMETRYFLOW_MCP_QUEUE_CONCURRENCY=5


#================================================================================================
# [9] NATS (Message Queue — JetStream)
#================================================================================================
TELEMETRYFLOW_MCP_NATS_URL=nats://localhost:4222


#================================================================================================
# [10] POSTGRESQL
#================================================================================================
TELEMETRYFLOW_MCP_POSTGRES_URL=postgres://tfo_admin:telemetryflow123@localhost:5432/telemetryflow_mcp?sslmode=disable
TELEMETRYFLOW_MCP_DATABASE_ENABLED=true
TELEMETRYFLOW_MCP_DATABASE_AUTO_MIGRATE=true
TELEMETRYFLOW_MCP_POSTGRES_MAX_CONNS=25
TELEMETRYFLOW_MCP_POSTGRES_MIN_CONNS=5


#================================================================================================
# [11] CLICKHOUSE (Analytics)
#================================================================================================
TELEMETRYFLOW_MCP_CLICKHOUSE_URL=clickhouse://localhost:9000/telemetryflow_analytics
TELEMETRYFLOW_MCP_CLICKHOUSE_ENABLED=true


#================================================================================================
# [12] TELEMETRY CONFIGURATION
#================================================================================================
TELEMETRYFLOW_MCP_TELEMETRY_ENABLED=true
TELEMETRYFLOW_MCP_TELEMETRY_BACKEND=telemetryflow

# SDK Advanced Settings
TELEMETRYFLOW_PROTOCOL=grpc
TELEMETRYFLOW_INSECURE=false
TELEMETRYFLOW_TIMEOUT=30
TELEMETRYFLOW_COMPRESSION=true
TELEMETRYFLOW_ENABLE_TRACES=true
TELEMETRYFLOW_ENABLE_METRICS=true
TELEMETRYFLOW_ENABLE_LOGS=true
TELEMETRYFLOW_ENABLE_EXEMPLARS=true
TELEMETRYFLOW_BATCH_TIMEOUT_MS=5000
TELEMETRYFLOW_BATCH_MAX_SIZE=512
TELEMETRYFLOW_RETRY_ENABLED=true
TELEMETRYFLOW_MAX_RETRIES=3
TELEMETRYFLOW_RETRY_BACKOFF_MS=500
TELEMETRYFLOW_RATE_LIMIT=1000


#================================================================================================
# [13] SECURITY
#================================================================================================
# TELEMETRYFLOW_MCP_SECURITY_REQUIRE_API_KEY=false
# TELEMETRYFLOW_MCP_SECURITY_RATE_LIMIT_PER_MINUTE=100


#================================================================================================
# [14] TFO-COLLECTOR & TFO-AGENT (Profiles: full)
#================================================================================================
TFO_COLLECTOR_VERSION=1.2.1
TFO_AGENT_VERSION=1.2.0
TFO_AGENT_HOSTNAME=tfo-agent-mcp
TFO_AGENT_HEARTBEAT_INTERVAL=60s
TFO_AGENT_METRICS_INTERVAL=30s
TELEMETRYFLOW_BACKEND_ENDPOINT=http://localhost:3000


#================================================================================================
# [15] PROMETHEUS (Profile: full)
#================================================================================================
PROMETHEUS_VERSION=v2.54.1
PORT_PROMETHEUS=9090


#================================================================================================
# [16] TFO-PLATFORM SERVICES (Profile: platform)
#================================================================================================
TFO_PLATFORM_VERSION=1.4.0

# PostgreSQL
POSTGRES_VERSION=16-alpine
POSTGRES_DB=telemetryflow_mcp
POSTGRES_USERNAME=tfo_admin
POSTGRES_PASSWORD=telemetryflow123
PORT_POSTGRES=5432

# ClickHouse
CLICKHOUSE_VERSION=latest
CLICKHOUSE_DB=telemetryflow_analytics
CLICKHOUSE_USER=tfo_admin
CLICKHOUSE_PASSWORD=telemetryflow123
PORT_CLICKHOUSE_HTTP=8123
PORT_CLICKHOUSE_NATIVE=9000

# Redis
REDIS_VERSION=7-alpine
REDIS_PASSWORD=
REDIS_MAX_MEMORY=256mb
PORT_REDIS=6379

# NATS
NATS_VERSION=2-alpine
NATS_URL=nats://localhost:4222
NATS_CLUSTER_ID=telemetryflow-cluster
PORT_NATS_CLIENT=4222
PORT_NATS_MONITOR=8222

# TFO-Backend (NestJS API)
NODE_ENV=development
PORT_BACKEND=3000
ENABLE_BULLMQ=true
JWT_SECRET=dev-secret-change-me-in-production
JWT_EXPIRES_IN=24h
SESSION_SECRET=dev-session-secret-change-me
CORS_ORIGIN=*
LOGGER_TYPE=winston
LOG_PRETTY_PRINT=false
OTEL_SERVICE_NAME=telemetryflow-platform

# TFO-Viz (Frontend)
PORT_FRONTEND=8081


#================================================================================================
# [17] CONTAINER NAMES
#================================================================================================
CONTAINER_MCP=telemetryflow_mcp_server
CONTAINER_POSTGRES=telemetryflow_mcp_postgres
CONTAINER_CLICKHOUSE=telemetryflow_mcp_clickhouse
CONTAINER_REDIS=telemetryflow_mcp_redis
CONTAINER_NATS=telemetryflow_mcp_nats
CONTAINER_OTEL=telemetryflow_mcp_tfo_collector
CONTAINER_TFO_AGENT=telemetryflow_mcp_tfo_agent
CONTAINER_PROMETHEUS=telemetryflow_mcp_prometheus
CONTAINER_BACKEND=telemetryflow_mcp_backend
CONTAINER_FRONTEND=telemetryflow_mcp_frontend


#================================================================================================
# [18] PORT MAPPINGS
#================================================================================================
TELEMETRYFLOW_MCP_PORT=8080
PORT_OTEL_GRPC=4317
PORT_OTEL_HTTP=4318
PORT_OTEL_METRICS=8889
PORT_OTEL_HEALTH=13133
PORT_TFO_AGENT=9191


#================================================================================================
# [19] STATIC IP ADDRESSES (Docker internal — 172.153.0.0/16)
#================================================================================================
# MCP Services
CONTAINER_IP_MCP=172.153.152.10

# Monitoring Services
CONTAINER_IP_OTEL=172.153.152.30
CONTAINER_IP_TFO_AGENT=172.153.152.35
CONTAINER_IP_PROMETHEUS=172.153.152.70

# Infrastructure Services
CONTAINER_IP_POSTGRES=172.153.153.20
CONTAINER_IP_CLICKHOUSE=172.153.153.40
CONTAINER_IP_REDIS=172.153.153.50
CONTAINER_IP_NATS=172.153.153.55

# Platform Services
CONTAINER_IP_BACKEND=172.153.153.10
CONTAINER_IP_FRONTEND=172.153.153.15


#================================================================================================
# [20] SERVICE VERSIONS
#================================================================================================
GO_VERSION=1.26
OTEL_GO_SDK_VERSION=1.43.0


#================================================================================================
# PRODUCTION DEPLOYMENT CHECKLIST
#================================================================================================
#
# [ ] ANTHROPIC_API_KEY set to valid key
# [ ] TELEMETRYFLOW_API_KEY_ID / TELEMETRYFLOW_API_KEY_SECRET set to valid platform keys
# [ ] TELEMETRYFLOW_ENVIRONMENT set to production
# [ ] TELEMETRYFLOW_INSECURE set to false (enable TLS)
# [ ] JWT_SECRET / SESSION_SECRET changed from defaults
# [ ] POSTGRES_PASSWORD / CLICKHOUSE_PASSWORD changed from defaults
# [ ] TELEMETRYFLOW_ENDPOINT points to production collector
# [ ] TELEMETRYFLOW_BACKEND_ENDPOINT points to production backend
# [ ] HTTPS/TLS enabled at reverse proxy (nginx/traefik)
# [ ] CORS_ORIGIN set to specific trusted domains (no wildcard)
# [ ] TELEMETRYFLOW_MCP_SERVER_TRANSPORT set to sse or websocket
#
#================================================================================================
